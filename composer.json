{
    "name": "yourname/socialauth-connect",
    "description": "Modular social authentication plugin for WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.6",
        "wp-coding-standards/wpcs": "^3.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "classmap": [
            "includes/abstracts/",
            "includes/interfaces/",
            "includes/providers/",
            "includes/auth/",
            "includes/user/",
            "includes/admin/",
            "includes/frontend/",
            "includes/security/",
            "includes/helpers/",
            "includes/"
        ],
        "files": [
            "includes/helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "phpcs": "phpcs --standard=WordPress includes/",
        "phpcbf": "phpcbf --standard=WordPress includes/",
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
